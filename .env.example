# Run scripts/generate-ca.sh to generate these values.

# Base64-encoded CA certificate (public, safe to share)
CA_CERT=

# Base64-encoded CA private key (keep secret — never commit this)
CA_KEY=

# Header substitution rules for the proxy (JSON array)
# Example: [{"header":"Authorization","value":"op://vault/item/field"}]
CREDENTIAL_MAP=[]

# Optional: 1Password service account token (if using op:// references above)
OP_SERVICE_ACCOUNT_TOKEN=

# openclaw version to build/run (overrides OPENCLAW_VERSION file when set locally)
# OPENCLAW_VERSION=v2026.3.23

# Host port for the openclaw gateway
OPENCLAW_PORT=18789
